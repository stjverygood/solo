# ==========================================
# Godot Standard Ignore
# ==========================================
# Godot 自动生成的导入缓存
.godot/

# 导出项目时可能生成的二进制文件和安装包
*.import
export_presets.cfg

# 如果你不需要将本地的编辑器配置同步给团队
.config/

# ==========================================
# .NET / C# / Visual Studio Standard Ignore
# ==========================================
# 编译输出目录
[Bb]in/
[Oo]bj/

# MSBuild / Visual Studio 自动生成的缓存和依赖
.msbuild/
*.suo
*.user
*.userosscache
*.sln.docstates

# Rider / JetBrains 各种 IDE 的配置文件
.idea/
*.sln.DotSettings.user

# Visual Studio Code 配置
.vscode/
!.vscode/extensions.json

# ==========================================
# OS / System Specific
# ==========================================
# Windows 缩略图缓存
Thumbs.db
ehthumbs.db
Desktop.ini

# macOS 文件夹属性缓存
.DS_Store
.AppleDouble
.LSOverride

# ==========================================
# Crash Dumps & Logs
# ==========================================
*.log
*.crash


## 忽略编译产物
/[Bb]in/
/[Oo]bj/

## 忽略 Visual Studio 本地缓存和设置
.vs/
*.user
*.suo
*.userosscache
*.sln.docstates

## 忽略 Rider 等其他 IDE 的缓存（以防万一）
.idea/

## 忽略对外的敏感配置文件（如果有）
# appsettings.Development.json


/assetsraw